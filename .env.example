# =============================================================================
# Slickdeals Alerts - environment variables
# =============================================================================
# Copy this file: cp .env.example .env  (then fill in real values)
# Each app reads only the vars it needs - see apps/*/README.md
# =============================================================================

# ---- Supabase (everyone) ----------------------------------------------------
# Find these at: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=eyJhbGci...                  # public, safe to expose
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...           # SECRET - bypasses RLS, never ship to browser
SUPABASE_PROJECT_REF=YOUR_PROJECT_REF
SUPABASE_DB_PASSWORD=...                        # set when project is created

# ---- Telegram bot (notifier + telegram-webhook) -----------------------------
# Create a bot via @BotFather on Telegram, paste the token here
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_BOT_USERNAME=YourBotName               # without leading @
# Random string used as a "secret" path component on the webhook URL,
# so unsolicited POSTs to the function are rejected. Generate with:
#   openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=...

# ---- Poller (Fly.io) --------------------------------------------------------
POLL_INTERVAL_SECONDS=30                        # per-feed cadence target
POLL_MAX_CONCURRENT=2                           # max in-flight HTTP fetches
POLL_USER_AGENT="SlickdealsAlerts/0.1 (+contact@example.com)"
LOG_LEVEL=info

# ---- Dashboard (Next.js / Vercel) ------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=${SUPABASE_URL}
NEXT_PUBLIC_SUPABASE_ANON_KEY=${SUPABASE_ANON_KEY}
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=${TELEGRAM_BOT_USERNAME}
# Optional: restrict signups to a specific email domain
ALLOWED_EMAIL_DOMAIN=slickdeals.net

# ---- Optional: ntfy self-hosted ---------------------------------------------
# Leave empty to use the public ntfy.sh
NTFY_BASE_URL=https://ntfy.sh
